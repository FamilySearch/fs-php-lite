{
    "name": "familysearch/fs-php-lite",
    "description": "A lightweight PHP SDK for the FamilySearch API",
    "type": "library",
    "keywords": ["familysearch", "genealogy", "api", "sdk"],
    "authors": [
        {
            "name": "Justin",
            "email": "justincyork@gmail.com"
        }
    ],
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "gedcomx/gedcomx-php": "^3.1.2",
        "php-vcr/php-vcr": "^1.6",
        "phpunit/phpunit": "^10.5",
        "php-vcr/phpunit-testlistener-vcr": "^3.0"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "psr-4": {
            "FamilySearch\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:unit": "phpunit --testsuite Unit --no-coverage",
        "test:integration": "phpunit --testsuite Integration --no-coverage",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html coverage --coverage-clover coverage.xml"
    }
}
